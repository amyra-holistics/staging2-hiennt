Dataset public_ecommerce {
  __engine__: 'aql'
  label: 'Ecommerce'
  description: ''
  data_source_name: 'demodb'
  // metric total_orders {
  //   label: "Total Orders"
  //   type: 'number'
  //   definition: @aql count(public_persisted_orders.id) ;;
  // }
  models: [
    public_persisted_order_items,
    public_persisted_categories,
    public_persisted_cities,
    public_persisted_merchants,
    public_persisted_countries,
    public_persisted_orders,
    public_persisted_users,
    public_persisted_products,
  ]
  relationships: [
    relationship(public_persisted_order_items.product_id > public_persisted_products.id, true),
    relationship(public_persisted_order_items.order_id > public_persisted_orders.id, true),
    relationship(public_persisted_orders.user_id > public_persisted_users.id, true),
    relationship(public_persisted_cities.country_code > public_persisted_countries.code, true),
    relationship(public_persisted_users.city_id > public_persisted_cities.id, true),
    relationship(public_persisted_products.category_id > public_persisted_categories.id, true),
    relationship(public_persisted_products.merchant_id > public_persisted_merchants.id, true),


    // relationship(public_persisted_orders.created_date > public_persisted_dates.date_actual, true),
    // relationship(public_persisted_orders.received_date > public_persisted_dates.date_actual, false),
  ]
  owner: 'tri.dvm@holistics.io'
  // metric below_target {
  //   label: "below - target"
  //   type: "number"
  //   definition: @aql count(public_persisted_orders.id) - 0.4 * count(public_persisted_orders.id);;
  // }
  // metric above_target {
  //   label: "above - target"
  //   type: "number"
  //   definition: @aql count(public_persisted_orders.id) + 0.6 * count(public_persisted_orders.id);;
  // }
  metric equal_target {
    label: "Count Orders"
    type: "number"
    definition: @aql count(public_persisted_orders.id);;
  }
}

Dataset extended_ecommerce = public_ecommerce.extend({
  // metric total_orders {
  //   label: "Total Orders"
  //   type: 'number'
  //   definition: @aql count(public_persisted_order_item.order_id) | where(public_persisted_countries.name == 'Vietnam') ;;
  // }
})

