Model user_total_purchases {
  type: 'query'
  label: 'User Total Purchases'
  description: ''
  data_source_name: 'demodb'
  dimension user_id {
    label: 'User Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.user_id }};;
  }
  dimension total_purchase {
    label: 'Total Purchase'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.total_purchase }};;
  }

  owner: 'scott.bui@holistics.io'
  query: @sql
    select u.id user_id, sum(p.price * oi.quantity) total_purchase
        from ecommerce.users u
          left join ecommerce.orders o
            on o.user_id = u.id
          left join ecommerce.order_items oi
            on oi.order_id = o.id
          left join ecommerce.products p
            on p.id = oi.product_id
        group by u.id;;
  models: [
  ]
}
