Dataset ecommerce_dataset {
  label: 'Ecommerce Dataset'
  description: ''
  data_source_name: 'demodb'
  models: [
    ecommerce_users,
    ecommerce_orders,
    ecommerce_order_items
  ]
  relationships: [relationship(ecommerce_order_items.order_id > ecommerce_orders.id, true), relationship(ecommerce_orders.user_id > ecommerce_users.id, true)]
  owner: 'di.hoang@holistics.io'
}
