Dashboard ecommerce_dashboard_test_ai {
  title: 'Ecommerce Dashboard - Test AI'
  description: ''''''

  view: TabLayout {
    label: 'View 1'
    tab tab1: CanvasLayout {
      label: 'Business overview'
      width: 1245
      height: 890
      grid_size: 25
      block v1 {
        position: pos(25, 25, 250, 150)
        layer: 1
      }
      block v2 {
        position: pos(25, 175, 250, 150)
        layer: 2
      }
      block v3 {
        position: pos(300, 25, 500, 300)
        layer: 3
      }
      block v4 {
        position: pos(825, 25, 400, 300)
        layer: 4
      }
      block v5 {
        position: pos(25, 350, 775, 525)
        layer: 5
      }
      block v6 {
        position: pos(825, 350, 400, 525)
        layer: 6
      }
    }
    tab tab2: CanvasLayout {
      label: 'Internal testing'
      width: 1340
      height: 800
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
      block t_7s4c {
        position: pos(20, 40, 420, 60)
        layer: 1
      }
      block t_0cuh {
        position: pos(460, 40, 420, 60)
        layer: 1
      }
      block t_kxcy {
        position: pos(20, 380, 420, 60)
        layer: 1
      }
      block t_vb19 {
        position: pos(900, 40, 420, 60)
        layer: 1
      }
      block t_1x42 {
        position: pos(460, 380, 420, 60)
        layer: 1
      }
    }
  }
  theme: H.themes.classic
  block v1: VizBlock {
    label: 'Total Users compared with Total Users (Prev. 1y)'
    viz: MetricKpi {
      dataset: ecommerce
      value: VizFieldFull {
        label: 'Total Users'
        ref: ref('ecommerce_orders', 'user_id')
        aggregation: 'count'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v2: VizBlock {
    label: 'Count of Order Id'
    viz: MetricKpi {
      dataset: ecommerce
      value: VizFieldFull {
        label: 'Total Orders'
        ref: ref('ecommerce_order_items', 'order_id')
        aggregation: 'count'
        format {
          type: 'number'
          pattern: 'inherited'
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
    settings {
      hide_label: true
    }
  }
  block v3: VizBlock {
    label: 'Total Users by Month Sign Up At'
    viz: LineChart {
      dataset: ecommerce
      filter {
        field: ref('ecommerce_users', 'sign_up_at')
        operator: 'matches'
        value: 'last 3 years'
      }
      x_axis: VizFieldFull {
        ref: ref('ecommerce_users', 'sign_up_at')
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Total Users'
            ref: ref('ecommerce_users', 'id')
            aggregation: 'count'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v4: VizBlock {
    label: 'Total Orders by Gender'
    viz: PieChart {
      dataset: ecommerce
      legend: VizFieldFull {
        ref: ref('ecommerce_users', 'gender')
        format {
          type: 'text'
        }
      }
      series {
        field: VizFieldFull {
          label: 'orders'
          ref: ref('ecommerce_orders', 'id')
          aggregation: 'count'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v5: VizBlock {
    label: 'Order Details'
    viz: DataTable {
      dataset: ecommerce
      theme {

      }
      fields: [
        VizFieldFull {
          ref: ref('ecommerce_orders', 'id')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_orders', 'created_at')
          transformation: 'datetrunc year'
          format {
            type: 'date'
            pattern: 'yyyy'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_orders', 'status')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_orders', 'discount')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_orders', 'delivery_attempts')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v6: VizBlock {
    label: 'Total Orders by Name'
    viz: ColumnChart {
      dataset: ecommerce
      x_axis: VizFieldFull {
        ref: ref('ecommerce_countries', 'name')
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        ref: ref('ecommerce_orders', 'status')
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            label: 'Total Orders'
            ref: ref('ecommerce_orders', 'id')
            aggregation: 'count'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block t_7s4c: TextBlock {
    content: @md Two metrics;;
  }
  block t_0cuh: TextBlock {
    content: @md Dataset metric;;
  }
  block t_kxcy: TextBlock {
    content: @md Metric with empty label;;
  }
  block t_vb19: TextBlock {
    content: @md Viz metric;;
  }
  block t_1x42: TextBlock {
    content: @md Viz with hidden title;;
  }
}