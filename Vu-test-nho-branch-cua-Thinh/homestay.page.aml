Dashboard homestay_dashboard {
  title: 'Homestay Dashboard'
  description: ''''''
  view: CanvasLayout {
    label: 'View 1'
    height: 800
    block v1 {
      position: pos(30, 90, 550, 310)
    }
    block t1 {
      position: pos(30, 30, 370, 60)
    }
  }
  block v1: VizBlock {
    label: 'Table'
    viz: DataTable {
      dataset: homestay
      fields: [
        VizFieldFull {
          ref: ref('homestay_hosts', 'id')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: ref('homestay_hosts', 'name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('homestay_hosts', 'listings_count')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
      }
    }
  }
  block t1: TextBlock {
    content: @md # Homestay Dashboard
;;
  }

}