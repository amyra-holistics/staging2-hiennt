Model ecommerce_sales_goals {
  type: 'table'
  label: 'Sales Goals'
  description: ''
  data_source_name: 'demodb'
  dimension month {
    label: 'Month'
    type: 'date'
    hidden: false
    definition: @sql {{ #SOURCE.month }};;
  }
  dimension orders_goal {
    label: 'Orders Goal'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.orders_goal }};;
  }

  owner: 'tien.tt@holistics.io'
  table_name: '"ecommerce"."sales_goals"'
}
