Dashboard merge_conflict {
  title: 'Merge Conflict'
  description: 'Demo dashboard'
  block guide: TextBlock {
    content: @md <img alt="a"  src="https://cdn.holistics.io/product/modeling-merge-conflict-diagram-20241210-467.png"/>;;
  }
  block t1: TextBlock {
    content: @md <img alt="b"  src="https://cdn.holistics.io/docs/git/merge-conflict.png"/>;;
  }

  view: CanvasLayout {
    label: 'View 1'
    height: 1060
    grid_size: 20
    block guide {
      position: pos(0, 0, 1200, 480)
    }
    block t1 {
      position: pos(0, 480, 1200, 580)
    }
  }

  theme: H.themes.classic
}