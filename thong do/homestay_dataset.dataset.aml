Dataset homestay_dataset_thong {
  label: 'Homestay Dataset'
  description: '123'
  data_source_name: 'demodb'
  models: [
    homestay_hosts_thong,
    homestay_listings_thong
  ]
  relationships: [
    relationship(homestay_listings_thong.host_id > homestay_hosts_thong.id, true)
  ]
  owner: 'thong.do@holistics.io'
}
