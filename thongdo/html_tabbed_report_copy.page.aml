        </div>
        <div class="dh-chart tall dh-chart-live"><h-block name="v_tab_trend" /></div>
      </div>
      <div class="dh-card dh-col-5">
        <div class="dh-card-header">
          <div>
            <div class="dh-card-eyebrow">Mix</div>
