Model ecommerce_categories_1 {
  type: 'table'
  label: 'Categories'
  description: 'test description for product category of ecommerce'
  data_source_name: 'snowflake'
  dimension id {
    label: 'Id'
    type: 'number'
    hidden: false
    description: 'field'
    definition: @sql {{ #SOURCE.ID }};;
  }
  dimension name {
    label: 'Name'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.NAME }};;
  }
  dimension parent_id {
    label: 'Parent Id'
    type: 'number'
    hidden: false
    definition: @sql {{ #SOURCE.PARENT_ID }};;
  }

  owner: 'vu.dq@holistics.io'
  table_name: '"ECOMMERCE"."CATEGORIES"'
}
